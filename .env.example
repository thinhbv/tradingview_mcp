# Telegram Bot Configuration
# Sao chép file này thành .env và điền thông tin thực

# 1. Lấy từ @BotFather trên Telegram (tạo bot mới → /newbot)
TELEGRAM_TOKEN=

# 2. Chat ID của bạn
#    Cách lấy: Gửi /start cho bot → truy cập
#    https://api.telegram.org/bot<TOKEN>/getUpdates
#    Tìm "chat": { "id": 123456789 }
TELEGRAM_CHAT_ID=123456789

ANTHROPIC_API_KEY = this_is_a_test_key
